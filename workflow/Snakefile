######################################################################################
#%% WORKFLOW CONFIGURATION
######################################################################################
import pandas as pd
import os

configfile: "workflow/config/config.yaml"
project = config["project"]

collapse_config_df = pd.read_csv(config["collapse_config"],
                     sep="\t", 
                     dtype={"target_col": str}).set_index("target_col", drop=False)
TARGET_COLS = collapse_config_df.index.tolist()

histograms_config_df = pd.read_csv(config["histograms_config"], 
                     sep="\t", 
                     dtype={"#colname": str}).set_index("#colname", drop=False)
HIST_COLS = histograms_config_df.index.tolist()

## Declaring directory variables.
dir_d = "data/"
dir_s = "src/"
dir_w = "workflow/"
dir_r = f"results/{project}/"
dir_r0 = f"{dir_r}0_data/"
dir_r1 = f"{dir_r}1_metadata/"
dir_r2 = f"{dir_r}2_histograms/"
dir_r3 = f"{dir_r}3_fastq_downloads/"
dir_r4 = f"{dir_r}4_krona_plots/"
dir_r5 = f"{dir_r}5_map/"

## Ensuring all the previously declared directories exist.
os.makedirs(dir_d, exist_ok=True)
os.makedirs(dir_s, exist_ok=True)
os.makedirs(dir_w, exist_ok=True)
os.makedirs(dir_r0, exist_ok=True)
os.makedirs(dir_r1, exist_ok=True)
os.makedirs(dir_r2, exist_ok=True)
os.makedirs(dir_r3, exist_ok=True)
os.makedirs(dir_r4, exist_ok=True)
os.makedirs(dir_r5, exist_ok=True)

######################################################################################
#%% WORKFLOW RULES
######################################################################################
rule all:
    input: dir_r2 + "histogram.png"

rule check_bioprojects_list:
    input: config["bioprojects_list"]
    output: dir_r0 + "bio-projects.txt"
    shell: "ln -s $(realpath {input}) {output}"

rule get_bioprojects_metadata:
    input: dir_r0 + "bio-projects.txt"
    output: dir_r1 + "raw_metadata.tsv"
    params: outdir=dir_r1
    shell: "./src/get_metadata.sh {input} {params.outdir}"

rule categorize_metadata:
    input:
        metadata=dir_r1 + "raw_metadata.tsv",
        categories=lambda wc: collapse_config_df.loc[wc.col, "categories"]
    output:
        dir_r1 + "categorized-{col}_metadata.tsv"
    params:
        id_col=lambda wc: collapse_config_df.loc[wc.col, "id_col"],
        outdir=dir_r1
    shell:
        "python ./src/categorize_tsv_fields.py {input.metadata} {wildcards.col} "
        "-i {params.id_col} -O {params.outdir} -C {input.categories}"

rule create_clean_metadata:
    input: raw=dir_r1 + "raw_metadata.tsv",
           tsvs=expand(dir_r1 + "categorized-{col}_metadata.tsv", col=TARGET_COLS)
    output: dir_r1 + "clean_metadata.tsv"
    shell: "./src/merge_categorized_tsvs.sh {input.raw} {output} {input.tsvs}"

rule launch_app:
    input: dir_r1 + "clean_metadata.tsv"
    output: dir_r2 + "histogram.png"
    shell: "streamlit run ./src/main.py"